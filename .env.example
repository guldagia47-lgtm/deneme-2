# Client-side env variables used by the Vite app
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=http://localhost:5173

# Server-side only: keep these out of the browser bundle
# Use them in a backend route, edge function, or Supabase SMTP config.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL="ModelForge <no-reply@yourdomain.com>"

# Server-side only: use these in the /api/generate-model backend route.
TRIPO_API_KEY=tripo_your_api_key
MESHY_API_KEY=msy_your_api_key

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_FREE=price_free_placeholder
STRIPE_PRICE_ID_PRO=price_pro_placeholder
STRIPE_PRICE_ID_PREMIUM=price_premium_placeholder